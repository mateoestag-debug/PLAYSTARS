<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="PlayStars">
<meta name="application-name" content="PlayStars">
<meta name="theme-color" content="#0d2818">
<link rel="manifest" href="data:application/json;base64,">
<link rel="apple-touch-icon" href="data:image/svg+xml;base64,">
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml;base64,">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>PlayStars</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
:root{
  --g9:#0d2818;--g8:#1a3d26;--g7:#234f31;--g6:#2d6140;--g5:#3a7a51;--g4:#4e9a6b;--g3:#7ab895;--g2:#b0d9c0;--g1:#e0f0e8;
  --gold:#c9a84c;--gold-l:#e8c97a;--gold-d:#8a6a1e;
  --cream:#f8f4ec;--cream-d:#ede6d8;
  --td:#1a1a1a;--tm:#4a4a4a;--tl:#888;
  --wh:#ffffff;--danger:#c0392b;--ok:#27ae60;
  --sh:0 4px 24px rgba(0,0,0,.18);--sh-s:0 2px 8px rgba(0,0,0,.10);
  --r:16px;--rs:10px;
}
body{font-family:'DM Sans',sans-serif;background:var(--g9);color:var(--td);min-height:100vh;overflow-x:hidden;max-width:430px;margin:0 auto;}
.screen{display:none;min-height:100vh;flex-direction:column;}
.screen.active{display:flex;}

/* AUTH */
#screen-auth{
  background:linear-gradient(160deg,var(--g9) 0%,var(--g8) 55%,#1c3a20 100%);
  flex-direction:column;align-items:center;justify-content:flex-start;
  padding:3rem 1.5rem 3rem;overflow-y:auto;-webkit-overflow-scrolling:touch;
  min-height:100vh;
}
.auth-logo{text-align:center;margin-bottom:2rem;width:100%;}
.auth-logo-icon{
  width:72px;height:72px;
  background:linear-gradient(135deg,var(--gold),var(--gold-d));
  border-radius:20px;display:flex;align-items:center;justify-content:center;
  margin:0 auto 1rem;font-size:36px;
}
.auth-logo h1{font-family:'Playfair Display',serif;font-size:2.2rem;color:var(--wh);letter-spacing:1px;}
.auth-logo p{color:var(--g3);font-size:.82rem;margin-top:4px;letter-spacing:3px;text-transform:uppercase;}
.auth-card{background:var(--wh);border-radius:var(--r);padding:2rem;width:100%;max-width:400px;}
.auth-tabs{display:flex;background:var(--cream);border-radius:var(--rs);padding:4px;margin-bottom:1.5rem;}
.auth-tab{
  flex:1;padding:10px;text-align:center;border-radius:8px;
  font-size:.9rem;font-weight:500;cursor:pointer;
  color:var(--tl);border:none;background:transparent;font-family:'DM Sans',sans-serif;
}
.auth-tab.active{background:var(--wh);color:var(--g8);}
.auth-form{display:none;}
.auth-form.active{display:block;}
.fg{margin-bottom:1.1rem;}
.fg label{display:block;font-size:.75rem;font-weight:600;color:var(--tm);margin-bottom:6px;text-transform:uppercase;letter-spacing:.5px;}
.fg input,.fg select{
  display:block;width:100%;padding:14px 16px;
  border:2px solid var(--cream-d);border-radius:var(--rs);
  font-size:16px;font-family:'DM Sans',sans-serif;
  color:var(--td);background:var(--cream);
  -webkit-appearance:none;appearance:none;outline:none;
  transition:border-color .2s;
}
.fg input:focus,.fg select:focus{border-color:var(--g6);background:var(--wh);}
.btn-p{
  display:block;width:100%;padding:15px;
  background:var(--g7);color:var(--wh);border:none;
  border-radius:var(--rs);font-size:1rem;font-weight:600;
  cursor:pointer;font-family:'DM Sans',sans-serif;margin-top:8px;
}
.btn-p:active{background:var(--g8);}
.btn-s{display:block;width:100%;padding:13px;background:var(--cream);color:var(--g8);border:2px solid var(--cream-d);border-radius:var(--rs);font-size:.95rem;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;margin-top:8px;}
.auth-err{color:var(--danger);font-size:.82rem;text-align:center;margin-top:8px;min-height:18px;}

/* MAIN */
#screen-main{background:var(--cream);flex-direction:column;}
.topbar{background:var(--g9);padding:1rem 1.25rem .75rem;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;}
.topbar-logo{font-family:'Playfair Display',serif;color:var(--wh);font-size:1.3rem;display:flex;align-items:center;gap:8px;}
.avatar{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,var(--gold),var(--gold-d));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.8rem;color:var(--wh);cursor:pointer;}
.lang-btn{background:rgba(255,255,255,.1);border:none;color:var(--wh);font-size:.75rem;padding:4px 10px;border-radius:20px;cursor:pointer;font-family:'DM Sans',sans-serif;}
.bottom-nav{background:var(--wh);border-top:1px solid var(--cream-d);display:flex;position:sticky;bottom:0;z-index:100;padding-bottom:env(safe-area-inset-bottom,0);}
.nav-item{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:8px 2px 6px;cursor:pointer;border:none;background:transparent;}
.nav-icon{font-size:20px;line-height:1;margin-bottom:2px;}
.nav-label{font-size:.6rem;font-weight:500;color:var(--tl);}
.nav-dot{width:4px;height:4px;border-radius:50%;background:var(--g6);margin:0 auto 2px;opacity:0;}
.nav-item.active .nav-label{color:var(--g7);}
.nav-item.active .nav-dot{opacity:1;}
.content{flex:1;overflow-y:auto;}
.tab-content{display:none;padding:1.25rem;}
.tab-content.active{display:block;}
.section-title{font-family:'Playfair Display',serif;font-size:1.5rem;color:var(--g9);margin-bottom:1.25rem;font-weight:700;}
.recent-title{font-size:.8rem;font-weight:600;color:var(--tm);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px;}

/* HOME */
.profile-hero{background:linear-gradient(135deg,var(--g8),var(--g9));border-radius:var(--r);padding:1.5rem;margin-bottom:1.25rem;color:var(--wh);position:relative;overflow:hidden;}
.profile-hero::after{content:'⛳';position:absolute;right:1rem;bottom:-4px;font-size:72px;opacity:.08;pointer-events:none;}
.hero-name{font-family:'Playfair Display',serif;font-size:1.4rem;margin-bottom:4px;}
.hcp-badge{display:inline-block;background:linear-gradient(135deg,var(--gold),var(--gold-d));padding:6px 18px;border-radius:30px;font-size:1.5rem;font-weight:700;}
.stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:1.25rem;}
.stat-card{background:var(--wh);border-radius:var(--rs);padding:1rem;box-shadow:var(--sh-s);text-align:center;}
.stat-value{font-size:1.6rem;font-weight:700;color:var(--g8);font-family:'Playfair Display',serif;}
.stat-label{font-size:.75rem;color:var(--tl);font-weight:500;margin-top:2px;}
.round-card{background:var(--wh);border-radius:var(--rs);padding:1rem 1.25rem;margin-bottom:10px;box-shadow:var(--sh-s);display:flex;align-items:center;gap:12px;cursor:pointer;}
.round-score-circle{width:46px;height:46px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1rem;flex-shrink:0;}

/* NEW ROUND */
.game-modes{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:1.25rem;}
.game-mode-btn{background:var(--wh);border:2px solid transparent;border-radius:var(--rs);padding:14px 10px;text-align:center;cursor:pointer;box-shadow:var(--sh-s);}
.game-mode-btn.selected{border-color:var(--g6);background:var(--g1);}
.mode-icon{font-size:24px;margin-bottom:6px;}
.mode-name{font-size:.78rem;font-weight:600;color:var(--td);}
.mode-desc{font-size:.68rem;color:var(--tl);margin-top:2px;}
.round-setup{background:var(--wh);border-radius:var(--rs);padding:1.25rem;margin-bottom:1rem;box-shadow:var(--sh-s);}
.setup-row{display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--cream-d);}
.setup-row:last-child{border-bottom:none;}
.setup-label{font-size:.88rem;color:var(--tm);font-weight:500;}
.setup-input{width:130px;padding:8px 10px;border:2px solid var(--cream-d);border-radius:8px;font-size:16px;font-family:'DM Sans',sans-serif;text-align:center;-webkit-appearance:none;appearance:none;background:var(--cream);outline:none;}
.setup-input:focus{border-color:var(--g6);}

/* SCORECARD */
.sc-header{background:var(--g8);border-radius:var(--r) var(--r) 0 0;padding:1rem;color:var(--wh);text-align:center;}
.sc-header h2{font-family:'Playfair Display',serif;font-size:1.2rem;}
.sc-header p{font-size:.78rem;color:var(--g2);margin-top:4px;}
.sc-totals{display:grid;grid-template-columns:1fr 1fr 1fr;background:var(--g9);padding:12px;gap:8px;border-radius:0 0 var(--r) var(--r);margin-bottom:1rem;}
.sc-total-item{text-align:center;}
.sc-total-val{font-size:1.4rem;font-weight:700;color:var(--wh);font-family:'Playfair Display',serif;}
.sc-total-lbl{font-size:.65rem;color:var(--g3);text-transform:uppercase;letter-spacing:.5px;}
.hole-row{display:grid;grid-template-columns:32px 1fr 1fr 44px;gap:4px;align-items:center;padding:8px 4px;border-bottom:1px solid var(--cream-d);}
.hole-num{font-weight:700;font-size:.78rem;color:var(--g8);text-align:center;}
.hole-score-input{padding:6px;border:2px solid var(--cream-d);border-radius:8px;font-size:16px;font-weight:700;text-align:center;font-family:'DM Sans',sans-serif;color:var(--td);background:var(--wh);width:100%;-webkit-appearance:none;appearance:none;outline:none;}
.hole-score-input:focus{border-color:var(--g5);}
.sc-circle{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.72rem;font-weight:700;margin:0 auto;}
.c-eagle{background:#e0f4fb;color:#1a6b8a;border:2px solid #1a6b8a;}
.c-birdie{background:#e6f7ee;color:var(--ok);border:2px solid var(--ok);}
.c-par{background:var(--cream);color:var(--tm);}
.c-bogey{background:#fff8e6;color:var(--gold-d);border:2px solid var(--gold);}
.c-double{background:#fdecea;color:var(--danger);border:2px solid var(--danger);}

/* HISTORY */
.filter-row{display:flex;gap:8px;margin-bottom:1rem;overflow-x:auto;padding-bottom:4px;}
.filter-chip{padding:6px 14px;border-radius:20px;font-size:.78rem;font-weight:500;white-space:nowrap;cursor:pointer;border:2px solid var(--cream-d);background:var(--wh);color:var(--tm);}
.filter-chip.active{background:var(--g7);color:var(--wh);border-color:var(--g7);}
.history-card{background:var(--wh);border-radius:var(--rs);margin-bottom:10px;overflow:hidden;box-shadow:var(--sh-s);}
.history-card-header{background:var(--g9);padding:10px 14px;display:flex;justify-content:space-between;align-items:center;}
.history-course{font-family:'Playfair Display',serif;color:var(--wh);font-size:.95rem;}
.history-score-badge{background:var(--gold);color:var(--g9);font-weight:700;font-size:.9rem;padding:4px 12px;border-radius:20px;}
.history-card-body{padding:10px 14px;}
.history-meta{display:flex;gap:10px;flex-wrap:wrap;}
.history-meta-item{font-size:.76rem;color:var(--tl);}

/* STATS */
.chart-card{background:var(--wh);border-radius:var(--rs);padding:1.25rem;margin-bottom:1.25rem;box-shadow:var(--sh-s);}
.chart-title{font-size:.8rem;font-weight:600;color:var(--tm);text-transform:uppercase;letter-spacing:.5px;margin-bottom:12px;}

/* PROFILE */
.profile-card{background:var(--wh);border-radius:var(--rs);padding:1.5rem;margin-bottom:1rem;box-shadow:var(--sh-s);text-align:center;}
.profile-avatar-lg{width:72px;height:72px;border-radius:50%;margin:0 auto 12px;background:linear-gradient(135deg,var(--gold),var(--gold-d));display:flex;align-items:center;justify-content:center;font-size:1.6rem;font-weight:700;color:var(--wh);}
.settings-list{background:var(--wh);border-radius:var(--rs);overflow:hidden;box-shadow:var(--sh-s);}
.settings-item{display:flex;align-items:center;padding:14px 16px;border-bottom:1px solid var(--cream-d);cursor:pointer;}
.settings-item:last-child{border-bottom:none;}
.settings-icon{font-size:20px;width:32px;text-align:center;margin-right:12px;}
.settings-text{flex:1;}
.settings-title{font-size:.9rem;font-weight:500;color:var(--td);}
.settings-sub{font-size:.75rem;color:var(--tl);margin-top:1px;}
.toggle-btn{width:44px;height:24px;background:var(--cream-d);border-radius:12px;cursor:pointer;position:relative;border:none;flex-shrink:0;}
.toggle-btn.on{background:var(--g5);}
.toggle-btn::after{content:'';position:absolute;width:18px;height:18px;background:var(--wh);border-radius:50%;top:3px;left:3px;transition:.2s;}
.toggle-btn.on::after{left:23px;}

/* FRIENDS */
.friend-card{background:var(--wh);border-radius:var(--rs);padding:1rem 1.25rem;margin-bottom:10px;box-shadow:var(--sh-s);display:flex;align-items:center;gap:12px;cursor:pointer;}
.friend-avatar{width:44px;height:44px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.9rem;color:var(--wh);}
.friend-add-btn{padding:7px 14px;border-radius:20px;font-size:.78rem;font-weight:600;cursor:pointer;border:none;font-family:'DM Sans',sans-serif;flex-shrink:0;}
.friend-add-btn.add{background:var(--g7);color:var(--wh);}
.friend-add-btn.added{background:var(--cream-d);color:var(--tl);}
.friend-add-btn.remove{background:#fdecea;color:var(--danger);}
.tag-pill{display:inline-block;background:var(--g1);color:var(--g8);font-size:.65rem;font-weight:600;padding:2px 8px;border-radius:10px;margin-right:4px;}
.fstat-row{display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid var(--cream-d);}
.fstat-row:last-child{border-bottom:none;}

/* NEARBY */
.nearby-card{background:var(--wh);border-radius:var(--rs);padding:10px 14px;margin-bottom:8px;box-shadow:var(--sh-s);display:flex;align-items:center;gap:12px;cursor:pointer;}
.nearby-card:active{background:var(--g1);}

/* MODALS */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:200;display:none;align-items:flex-end;justify-content:center;}
.modal-overlay.open{display:flex;}
.modal-sheet{background:var(--wh);border-radius:var(--r) var(--r) 0 0;width:100%;max-width:430px;padding:1.5rem;max-height:90vh;overflow-y:auto;animation:su .28s ease;}
@keyframes su{from{transform:translateY(100%)}to{transform:translateY(0)}}
.modal-handle{width:40px;height:4px;background:var(--cream-d);border-radius:2px;margin:0 auto 1.25rem;}
.modal-title{font-family:'Playfair Display',serif;font-size:1.3rem;color:var(--g9);margin-bottom:1rem;}

/* ADMIN */
.admin-summary-card{background:var(--wh);border-radius:var(--rs);padding:1rem;box-shadow:var(--sh-s);text-align:center;}
.admin-summary-val{font-size:1.8rem;font-weight:700;color:var(--g8);font-family:'Playfair Display',serif;}
.admin-summary-lbl{font-size:.72rem;color:var(--tl);font-weight:500;margin-top:2px;}

/* MISC */
.empty-state{text-align:center;padding:3rem 1rem;}
.empty-icon{font-size:48px;margin-bottom:12px;opacity:.4;}
.empty-text{color:var(--tl);font-size:.9rem;}
.gold-badge{display:inline-block;background:linear-gradient(135deg,var(--gold),var(--gold-d));color:var(--wh);font-size:.7rem;font-weight:700;padding:2px 8px;border-radius:10px;text-transform:uppercase;}
.hcp-info{background:var(--g1);border-radius:var(--rs);padding:1rem;margin-bottom:1rem;}
.toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--g9);color:var(--wh);padding:10px 20px;border-radius:30px;font-size:.85rem;font-weight:500;z-index:300;opacity:0;transition:all .3s;pointer-events:none;white-space:nowrap;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
</style>
</head>
<body>

<!-- AUTH -->
<div id="screen-auth" class="screen active">
  <div class="auth-logo">
    <div class="auth-logo-icon">⭐</div>
    <h1>PlayStars</h1>
    <p id="auth-tagline">Powered by a DREAM</p>
  </div>
  <div class="auth-card">
    <div class="auth-tabs">
      <button class="auth-tab active" id="tab-login" onclick="switchAuthTab('login')">Login</button>
      <button class="auth-tab" id="tab-register" onclick="switchAuthTab('register')">Register</button>
    </div>
    <!-- LOGIN -->
    <div id="form-login" class="auth-form active">
      <div class="fg">
        <label id="lbl-username">Username</label>
        <input type="text" id="login-user" placeholder="your_username"
          autocomplete="username" autocorrect="off" autocapitalize="none" spellcheck="false">
      </div>
      <div class="fg">
        <label id="lbl-password">Password</label>
        <input type="password" id="login-pass" placeholder="Password" autocomplete="current-password">
      </div>
      <button class="btn-p" id="btn-login" onclick="doLogin()">Login</button>
      <div class="auth-err" id="login-error"></div>
    </div>
    <!-- REGISTER -->
    <div id="form-register" class="auth-form">
      <div class="fg">
        <label id="lbl-fullname">Full Name</label>
        <input type="text" id="reg-name" placeholder="John Smith"
          autocorrect="off" autocapitalize="words">
      </div>
      <div class="fg">
        <label id="lbl-username2">Username</label>
        <input type="text" id="reg-user" placeholder="johnsmith"
          autocorrect="off" autocapitalize="none" spellcheck="false">
      </div>
      <div class="fg">
        <label id="lbl-hcp">Initial Handicap</label>
        <input type="number" id="reg-hcp" placeholder="18.0" min="0" max="54" step="0.1" inputmode="decimal">
      </div>
      <div class="fg">
        <label id="lbl-password2">Password</label>
        <input type="password" id="reg-pass" placeholder="Password" autocomplete="new-password">
      </div>
      <button class="btn-p" id="btn-register" onclick="doRegister()">Create Account</button>
      <div class="auth-err" id="reg-error"></div>
    </div>
  </div>
</div>

<!-- MAIN -->
<div id="screen-main" class="screen">
  <div class="topbar">
    <div class="topbar-logo"><span>⭐</span> PlayStars</div>
    <div style="display:flex;align-items:center;gap:10px;">
      <button class="lang-btn" onclick="toggleLang()">🌐 <span id="lang-label">ES</span></button>
      <div class="avatar" id="user-avatar" onclick="showTab('profile')">PS</div>
    </div>
  </div>
  <div class="content">

    <!-- HOME -->
    <div id="tab-home" class="tab-content active">
      <div class="profile-hero">
        <div class="hero-name" id="hero-name">Player</div>
        <div style="font-size:.82rem;color:var(--g2);margin-bottom:1rem;" id="hero-hcp-label">Official Handicap Index</div>
        <div class="hcp-badge" id="hero-hcp">18.0</div>
      </div>
      <div class="stats-grid">
        <div class="stat-card"><div class="stat-value" id="stat-rounds">0</div><div class="stat-label" id="lbl-rounds-played">Rounds Played</div></div>
        <div class="stat-card"><div class="stat-value" id="stat-avg">–</div><div class="stat-label" id="lbl-avg-score">Avg Score</div></div>
        <div class="stat-card"><div class="stat-value" id="stat-best">–</div><div class="stat-label" id="lbl-best-round">Best Round</div></div>
        <div class="stat-card"><div class="stat-value" id="stat-trend">–</div><div class="stat-label" id="lbl-trend">Trend</div></div>
      </div>
      <div class="recent-title" id="lbl-recent-rounds">Recent Rounds</div>
      <div id="home-rounds-list"></div>
      <div id="home-empty" class="empty-state" style="display:none"><div class="empty-icon">🏌️</div><div class="empty-text" id="lbl-no-rounds">No rounds yet!</div></div>
    </div>

    <!-- NEW ROUND -->
    <div id="tab-newround" class="tab-content">
      <div class="section-title" id="lbl-new-round">New Round</div>
      <div class="recent-title" id="lbl-select-mode">Select Game Mode</div>
      <div class="game-modes" id="game-modes-grid"></div>
      <div id="nearby-section" style="margin-bottom:1rem;">
        <div id="nearby-status-bar" style="background:var(--wh);border-radius:var(--rs);padding:12px 14px;box-shadow:var(--sh-s);font-size:.85rem;color:var(--tm);display:flex;align-items:center;gap:8px;">
          <span id="nearby-icon">📍</span><span id="nearby-text">Detecting location...</span>
        </div>
        <div id="nearby-list" style="margin-top:8px;"></div>
      </div>
      <div class="round-setup">
        <div class="setup-row"><span class="setup-label" id="lbl-course">Course</span><input class="setup-input" type="text" id="setup-course" placeholder="Club Name" autocorrect="off"></div>

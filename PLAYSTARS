function openEditProfile(){
  document.getElementById('edit-name-input').value=currentUser.name;
  document.getElementById('edit-hcp-input').value=currentUser.handicap;
  document.getElementById('modal-edit-profile').classList.add('open');
}
function saveProfile(){
  var name=document.getElementById('edit-name-input').value.trim();
  var hcp=parseFloat(document.getElementById('edit-hcp-input').value)||currentUser.handicap;
  if(!name)return;
  currentUser.name=name;currentUser.handicap=hcp;
  var db=getDB();if(db.users&&db.users[currentUser.username]){db.users[currentUser.username].name=name;db.users[currentUser.username].handicap=hcp;}
  saveDB(db);closeModal('modal-edit-profile');updateUI();showToast(t('profileUpdated'));
}

// ── FRIENDS ──
var FCOLORS=['#2d6140','#3a7a51','#1a3d26','#8a6a1e','#185fa5','#993556'];
function fColor(u){return FCOLORS[u.charCodeAt(0)%FCOLORS.length];}
function fInit(name){return name.split(' ').map(function(w){return w[0];}).join('').slice(0,2).toUpperCase();}
function getFriends(){var db=getDB();return(db.friends||{})[currentUser.username]||[];}
function saveFriends(list){var db=getDB();if(!db.friends)db.friends={};db.friends[currentUser.username]=list;saveDB(db);}

function renderFriendsTab(){renderFriendSearch();renderRecommendations();renderFriendsList();}

function renderFriendSearch(){
  var q=(document.getElementById('friend-search-input').value||'').trim().toLowerCase();
  var el=document.getElementById('friend-search-results');
  if(!q){el.innerHTML='';return;}
  var users=getUsers(),friends=getFriends();
  var matches=Object.entries(users).filter(function(e){return e[0]!==currentUser.username&&e[0].toLowerCase().indexOf(q)>=0;}).slice(0,6);
  if(!matches.length){el.innerHTML='<div style="text-align:center;color:var(--tl);font-size:.85rem;padding:1rem;">'+(lang==='es'?'No se encontraron usuarios':'No users found')+'</div>';return;}
  el.innerHTML=matches.map(function(e){
    var username=e[0],u=e[1],isFriend=friends.indexOf(username)>=0;
    return '<div class="friend-card" onclick="openFriendProfile(\''+username+'\')">'
      +'<div class="friend-avatar" style="background:'+fColor(username)+';"> '+fInit(u.name)+'</div>'
      +'<div style="flex:1;"><div style="font-weight:600;font-size:.9rem;">'+u.name+'</div>'
      +'<div style="font-size:.75rem;color:var(--tl);">@'+username+' · HCP '+u.handicap+'</div></div>'
      +'<button class="friend-add-btn '+(isFriend?'added':'add')+'" onclick="event.stopPropagation();toggleFriend(\''+username+'\')">'+(isFriend?(lang==='es'?'✓ Amigo':'✓ Friend'):(lang==='es'?'+ Agregar':'+ Add'))+'</button></div>';
  }).join('');
}

function renderRecommendations(){
  var el=document.getElementById('recommendations-list'),section=document.getElementById('recommendations-section');
  if(!el||!section)return;
  var db=getDB(),allUsers=db.users||{},allFriends=db.friends||{};
  var myFriends=getFriends(),myRounds=getRounds(currentUser.username);
  var myCourses={};myRounds.forEach(function(r){myCourses[r.course.toLowerCase().trim()]=r.course;});
  function isCandidate(u){return u!==currentUser.username&&myFriends.indexOf(u)<0&&!!allUsers[u];}
  var scores={};
  Object.keys(allUsers).forEach(function(u){if(isCandidate(u))scores[u]={score:1,reasons:[]};});
  myFriends.forEach(function(f){
    (allFriends[f]||[]).forEach(function(u){
      if(!isCandidate(u))return;
      if(!scores[u])scores[u]={score:0,reasons:[]};
      scores[u].score+=3;
      var fn=(allUsers[f]||{}).name||f;
      var reason=lang==='es'?'Amigo de '+fn:'Friend of '+fn;
      if(scores[u].reasons.indexOf(reason)<0)scores[u].reasons.push(reason);
    });
  });
  Object.keys(db.rounds||{}).forEach(function(username){
    if(!isCandidate(username))return;
    (db.rounds[username]||[]).forEach(function(r){
      var key=r.course.toLowerCase().trim();
      if(myCourses[key]){
        if(!scores[username])scores[username]={score:0,reasons:[]};
        scores[username].score+=2;
        var cn=myCourses[key];
        var reason=lang==='es'?'Jugó en '+cn:'Played at '+cn;
        var alreadyHas=scores[username].reasons.some(function(x){return x.indexOf(cn)>=0;});
        if(!alreadyHas)scores[username].reasons.push(reason);
      }
    });
  });
  var recs=Object.keys(scores).map(function(k){return [k,scores[k]];}).sort(function(a,b){return b[1].score-a[1].score;}).slice(0,6);
  var lbl=document.getElementById('lbl-suggestions');if(lbl)lbl.textContent=t('suggestions');
  if(!recs.length){section.style.display='none';return;}
  section.style.display='block';
  el.innerHTML=recs.map(function(entry){
    var username=entry[0],data=entry[1],u=allUsers[username];if(!u)return'';
    if(!data.reasons.length)data.reasons.push(lang==='es'?'Nuevo en PlayStars':'New on PlayStars');
    var tags=data.reasons.slice(0,2).map(function(r){return '<span class="tag-pill">'+r+'</span>';}).join('');
    return '<div class="friend-card" onclick="openFriendProfile(\''+username+'\')">'
      +'<div class="friend-avatar" style="background:'+fColor(username)+';"> '+fInit(u.name)+'</div>'
      +'<div style="flex:1;min-width:0;"><div style="font-weight:600;font-size:.88rem;">'+u.name+'</div>'
      +'<div style="font-size:.73rem;color:var(--tl);">@'+username+' · HCP '+u.handicap+'</div>'
      +'<div style="margin-top:4px;">'+tags+'</div></div>'
      +'<button class="friend-add-btn add" onclick="event.stopPropagation();toggleFriend(\''+username+'\')">'+(lang==='es'?'+ Agregar':'+ Add')+'</button></div>';
  }).filter(Boolean).join('');
}

function renderFriendsList(){
  var friends=getFriends(),list=document.getElementById('friends-list'),empty=document.getElementById('friends-empty');
  if(!friends.length){list.innerHTML='';empty.style.display='block';return;}
  empty.style.display='none';
  var users=getUsers();
  list.innerHTML=friends.map(function(username){
    var u=users[username];if(!u)return'';
    var rounds=getRounds(username);
    var last=rounds[0]?rounds[0].course+' · '+rounds[0].date:(lang==='es'?'Sin rondas':'No rounds');
    return '<div class="friend-card" onclick="openFriendProfile(\''+username+'\')">'
      +'<div class="friend-avatar" style="background:'+fColor(username)+';"> '+fInit(u.name)+'</div>'
      +'<div style="flex:1;"><div style="font-weight:600;font-size:.9rem;">'+u.name+'</div>'
      +'<div style="font-size:.73rem;color:var(--tl);">@'+username+' · HCP '+u.handicap+'</div>'
      +'<div style="font-size:.71rem;color:var(--g6);margin-top:2px;">⛳ '+last+'</div></div>'
      +'<button class="friend-add-btn remove" onclick="event.stopPropagation();toggleFriend(\''+username+'\')">'+(lang==='es'?'Eliminar':'Remove')+'</button></div>';
  }).filter(Boolean).join('');
}

function toggleFriend(username){
  var friends=getFriends(),idx=friends.indexOf(username);
  if(idx>=0){friends.splice(idx,1);showToast(t('friendRemoved'));}
  else{friends.push(username);showToast(t('friendAdded'));}
  saveFriends(friends);renderFriendsList();renderFriendSearch();renderRecommendations();
}

function openFriendProfile(username){
  var db=getDB(),u=(db.users||{})[username];if(!u)return;
  document.getElementById('fmodal-avatar').style.background=fColor(username);
  document.getElementById('fmodal-avatar').textContent=' '+fInit(u.name);
  document.getElementById('fmodal-name').textContent=u.name;
  document.getElementById('fmodal-username').textContent='@'+username;
  document.getElementById('fmodal-hcp').textContent=u.handicap;
  document.getElementById('fmodal-compare-title').textContent=lang==='es'?'Comparación contigo':'Comparison with you';
  document.getElementById('fmodal-rounds-title').textContent=lang==='es'?'Rondas recientes':'Recent rounds';
  document.getElementById('fmodal-close-btn').textContent=lang==='es'?'Cerrar':'Close';
  var my=getRounds(currentUser.username),their=getRounds(username);
  var myAvg=my.length?(my.reduce(function(a,r){return a+r.total;},0)/my.length).toFixed(1):'–';
  var theirAvg=their.length?(their.reduce(function(a,r){return a+r.total;},0)/their.length).toFixed(1):'–';
  var myBest=my.length?Math.min.apply(null,my.map(function(r){return r.total;})):'–';
  var theirBest=their.length?Math.min.apply(null,their.map(function(r){return r.total;})):'–';
  var meL=lang==='es'?'Tú':'You',themL=u.name.split(' ')[0];
  document.getElementById('fmodal-comparison').innerHTML=
    '<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:4px;text-align:center;margin-bottom:10px;">'
    +'<div></div><div style="font-size:.75rem;font-weight:700;color:var(--g8);">'+meL+'</div><div style="font-size:.75rem;font-weight:700;color:#185fa5;">'+themL+'</div></div>'
    +[['HCP',currentUser.handicap,u.handicap],[lang==='es'?'Promedio':'Avg',myAvg,theirAvg],[lang==='es'?'Mejor':'Best',myBest,theirBest],[lang==='es'?'Rondas':'Rounds',my.length,their.length]].map(function(row){
      var mw=parseFloat(row[1])<parseFloat(row[2]),tw=parseFloat(row[2])<parseFloat(row[1]);
      return '<div class="fstat-row"><span style="font-size:.82rem;color:var(--tm);">'+row[0]+'</span><span style="font-size:.9rem;font-weight:700;color:'+(mw?'var(--ok)':'var(--td)')+';">'+row[1]+'</span><span style="font-size:.9rem;font-weight:700;color:'+(tw?'var(--ok)':'var(--td)')+';">'+row[2]+'</span></div>';
    }).join('');
  document.getElementById('fmodal-rounds').innerHTML=!their.length
    ?'<div style="text-align:center;color:var(--tl);font-size:.85rem;padding:1rem;">'+(lang==='es'?'Sin rondas':'No rounds')+'</div>'
    :their.slice(0,5).map(function(r){
      var d=r.vsPar,ds=d===0?'E':(d>0?'+'+d:String(d));
      var col=d<=0?'var(--ok)':d<=3?'var(--gold-d)':'var(--danger)';
      return '<div style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid var(--cream-d);">'
        +'<div style="width:36px;height:36px;border-radius:50%;background:var(--g1);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.88rem;color:var(--g8);flex-shrink:0;">'+r.total+'</div>'
        +'<div style="flex:1;"><div style="font-size:.85rem;font-weight:600;">'+r.course+'</div><div style="font-size:.72rem;color:var(--tl);">'+r.date+' · '+r.mode+'</div></div>'
        +'<div style="font-weight:700;font-size:.85rem;color:'+col+';">'+ds+'</div></div>';
    }).join('');
  document.getElementById('modal-friend-profile').classList.add('open');
}

// ── ADMIN ──
function renderAdminPanel(){
  var db=getDB(),users=db.users||{},allRounds=db.rounds||{};
  var flat=[];Object.keys(allRounds).forEach(function(u){(allRounds[u]||[]).forEach(function(r){flat.push(Object.assign({},r,{_user:u}));});});
  flat.sort(function(a,b){return b.id-a.id;});
  var totalU=Object.keys(users).length,totalR=flat.length;
  var avgHcp=totalU?(Object.values(users).reduce(function(s,u){return s+parseFloat(u.handicap||0);},0)/totalU).toFixed(1):'–';
  document.getElementById('admin-summary-cards').innerHTML=
    '<div class="admin-summary-card"><div class="admin-summary-val">'+totalU+'</div><div class="admin-summary-lbl">Total Users</div></div>'
    +'<div class="admin-summary-card"><div class="admin-summary-val">'+totalR+'</div><div class="admin-summary-lbl">Total Rounds</div></div>'
    +'<div class="admin-summary-card"><div class="admin-summary-val">'+avgHcp+'</div><div class="admin-summary-lbl">Avg Handicap</div></div>'
    +'<div class="admin-summary-card"><div class="admin-summary-val">'+(flat.length?flat[0]._user:'–')+'</div><div class="admin-summary-lbl">Last Active</div></div>';
  var ul=document.getElementById('admin-users-list');
  ul.innerHTML=!totalU?'<div class="empty-state"><div class="empty-icon">👤</div><div class="empty-text">No users yet.</div></div>'
    :Object.keys(users).map(function(username){
      var u=users[username],ur=(allRounds[username]||[]).length;
      return '<div style="background:var(--wh);border-radius:var(--rs);padding:1rem 1.25rem;margin-bottom:10px;box-shadow:var(--sh-s);display:flex;align-items:center;gap:12px;">'
        +'<div style="width:40px;height:40px;border-radius:50%;background:'+fColor(username)+';display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.85rem;color:var(--wh);">'+fInit(u.name)+'</div>'
        +'<div style="flex:1;"><div style="font-weight:600;font-size:.92rem;">'+u.name+' <span style="font-size:.75rem;color:var(--tl);">@'+username+'</span></div>'
        +'<div style="font-size:.76rem;color:var(--tl);">HCP: '+u.handicap+' · '+ur+' round'+(ur!==1?'s':'')+'</div></div>'
        +'<div style="background:var(--g1);color:var(--g8);font-size:.8rem;font-weight:700;padding:6px 12px;border-radius:20px;">'+u.handicap+'</div></div>';
    }).join('');
  var rl=document.getElementById('admin-rounds-list');
  rl.innerHTML=!flat.slice(0,20).length?'<div class="empty-state"><div class="empty-icon">📋</div><div class="empty-text">No rounds yet.</div></div>'
    :flat.slice(0,20).map(function(r){
      var d=r.vsPar,ds=d===0?'E':(d>0?'+'+d:String(d));
      var col=d<=0?'var(--g8)':d<=3?'var(--gold-d)':'var(--danger)';
      var bg=d<=0?'var(--g1)':d<=3?'#fff8e6':'#fdecea';
      return '<div style="background:var(--wh);border-radius:var(--rs);padding:10px 14px;margin-bottom:8px;box-shadow:var(--sh-s);display:flex;align-items:center;gap:10px;">'
        +'<div style="width:38px;height:38px;border-radius:50%;background:'+bg+';color:'+col+';display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.88rem;flex-shrink:0;">'+r.total+'</div>'
        +'<div style="flex:1;"><div style="font-size:.88rem;font-weight:600;">'+r.course+'</div>'
        +'<div style="font-size:.73rem;color:var(--tl);">@'+r._user+' · '+r.date+' · '+r.mode+' · '+ds+'</div></div></div>';
    }).join('');
  var mc=document.getElementById('admin-mode-stats'),modeC={};
  MODES.forEach(function(m){modeC[m.id]=0;});flat.forEach(function(r){if(modeC[r.mode]!==undefined)modeC[r.mode]++;});
  var maxM=Math.max.apply(null,Object.values(modeC));if(!maxM)maxM=1;
  mc.innerHTML=MODES.map(function(m){
    return '<div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">'
      +'<span style="font-size:18px;">'+m.icon+'</span><div style="flex:1;">'
      +'<div style="display:flex;justify-content:space-between;margin-bottom:3px;">'
      +'<span style="font-size:.82rem;font-weight:500;">'+m.id+'</span>'
      +'<span style="font-size:.78rem;color:var(--tl);">'+modeC[m.id]+' rounds</span></div>'
      +'<div style="background:var(--cream-d);border-radius:4px;height:6px;overflow:hidden;">'
      +'<div style="background:var(--g5);width:'+(modeC[m.id]/maxM*100).toFixed(0)+'%;height:100%;border-radius:4px;"></div></div>'
      +'</div></div>';
  }).join('');
}
function adminDeleteRounds(){
  var u=document.getElementById('admin-delete-user').value.trim();
  var msg=document.getElementById('admin-delete-msg');
  if(!u){msg.style.color='var(--danger)';msg.textContent='Enter a username.';return;}
  var db=getDB();
  if(!db.rounds||!db.rounds[u]){msg.style.color='var(--danger)';msg.textContent='User not found or has no rounds.';return;}
  db.rounds[u]=[];saveDB(db);
  msg.style.color='var(--ok)';msg.textContent='All rounds deleted for @'+u;
  document.getElementById('admin-delete-user').value='';
  renderAdminPanel();
}

// ── UTILS ──
function closeModal(id){document.getElementById(id).classList.remove('open');}
function showToast(msg){var el=document.getElementById('toast');el.textContent=msg;el.classList.add('show');setTimeout(function(){el.classList.remove('show');},2500);}

// ── INIT ──
document.addEventListener('DOMContentLoaded',function(){
  applyLang();
  document.querySelectorAll('.modal-overlay').forEach(function(o){
    o.addEventListener('click',function(e){if(e.target===o)o.classList.remove('open');});
  });
});
</script>

<script>
if('serviceWorker' in navigator){
  window.addEventListener('load', function(){
    // Inline service worker as blob
    var swCode = `
const CACHE = 'playstars-v1';
self.addEventListener('install', e => e.waitUntil(caches.open(CACHE)));
self.addEventListener('fetch', e => {
  e.respondWith(
    caches.match(e.request).then(r => r || fetch(e.request).catch(() => caches.match(e.request)))
  );
});
    `;
    var blob = new Blob([swCode], {type: 'application/javascript'});
    var url = URL.createObjectURL(blob);
    navigator.serviceWorker.register(url).catch(function(){});
  });
}
</script>

// ── AUTH ──
function switchAuthTab(tab){
  document.getElementById('form-login').classList.toggle('active',tab==='login');
  document.getElementById('form-register').classList.toggle('active',tab==='register');
  document.getElementById('tab-login').classList.toggle('active',tab==='login');
  document.getElementById('tab-register').classList.toggle('active',tab==='register');
}
function doLogin(){
  var user=document.getElementById('login-user').value.trim();
  var pass=document.getElementById('login-pass').value;
  document.getElementById('login-error').textContent='';
  if(user===ADMIN_USER&&pass===ADMIN_PASS){currentUser={name:'Mateo',username:ADMIN_USER,handicap:0,isAdmin:true};enterAdmin();return;}
  var users=getUsers();
  if(users[user]&&users[user].password===pass){
    currentUser=Object.assign({},users[user],{username:user});
    enterApp();
  }else{document.getElementById('login-error').textContent=t('loginError');}
}
function doRegister(){
  var name=document.getElementById('reg-name').value.trim();
  var user=document.getElementById('reg-user').value.trim();
  var hcp=parseFloat(document.getElementById('reg-hcp').value)||18.0;
  var pass=document.getElementById('reg-pass').value;
  document.getElementById('reg-error').textContent='';
  if(!name||!user||!pass){document.getElementById('reg-error').textContent=t('regErrorEmpty');return;}
  var db=getDB();
  if(!db.users)db.users={};
  if(db.users[user]){document.getElementById('reg-error').textContent=t('regError');return;}
  db.users[user]={name:name,password:pass,handicap:hcp};
  saveDB(db);
  currentUser={name:name,username:user,handicap:hcp};
  enterApp();
}
function enterApp(){
  document.getElementById('screen-auth').classList.remove('active');
  document.getElementById('screen-admin').classList.remove('active');
  document.getElementById('screen-main').classList.add('active');
  updateUI();showTab('home');
}

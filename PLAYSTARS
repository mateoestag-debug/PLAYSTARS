// ── GEOLOCATION ──
function setNearbyStatus(icon,text){
  var i=document.getElementById('nearby-icon'),tx=document.getElementById('nearby-text');
  if(i)i.textContent=icon;if(tx)tx.textContent=text;
}
function fetchNearbyCourses(){
  setNearbyStatus('📍',t('nearbyDetecting'));
  if(!navigator.geolocation){setNearbyStatus('📍',t('nearbyEnable'));return;}
  navigator.geolocation.getCurrentPosition(
    function(pos){setNearbyStatus('🔍',t('nearbySearching'));searchGolfCourses(pos.coords.latitude,pos.coords.longitude);},
    function(){setNearbyStatus('📍',t('nearbyEnable'));},
    {timeout:8000,maximumAge:60000}
  );
}
function searchGolfCourses(lat,lon){
  var q='[out:json][timeout:15];(node["leisure"="golf_course"](around:25000,'+lat+','+lon+');way["leisure"="golf_course"](around:25000,'+lat+','+lon+');relation["leisure"="golf_course"](around:25000,'+lat+','+lon+'););out center tags 20;';
  fetch('https://overpass-api.de/api/interpreter',{method:'POST',body:'data='+encodeURIComponent(q)})
    .then(function(r){return r.json();})
    .then(function(data){
      var seen={};nearbyCourses=[];
      data.elements.forEach(function(el){
        var name=el.tags&&(el.tags.name||el.tags['name:en']||el.tags['name:es']);
        if(!name||seen[name])return;seen[name]=true;
        var elLat=el.lat||(el.center&&el.center.lat);
        var elLon=el.lon||(el.center&&el.center.lon);
        var dist='';
        if(elLat&&elLon){var d=geoDist(lat,lon,elLat,elLon);dist=d<1?Math.round(d*1000)+' m':d.toFixed(1)+' km';}
        nearbyCourses.push({name:name,dist:dist,address:el.tags['addr:city']||el.tags['addr:suburb']||''});
      });
      if(nearbyCourses.length===0)setNearbyStatus('🏌️',t('nearbyNone'));
      else{document.getElementById('nearby-status-bar').style.display='none';renderNearbyCoursesList();}
    })
    .catch(function(){setNearbyStatus('⚠️',t('nearbyError'));});
}
function geoDist(la1,lo1,la2,lo2){
  var R=6371,dL=(la2-la1)*Math.PI/180,dO=(lo2-lo1)*Math.PI/180;
  var a=Math.sin(dL/2)*Math.sin(dL/2)+Math.cos(la1*Math.PI/180)*Math.cos(la2*Math.PI/180)*Math.sin(dO/2)*Math.sin(dO/2);
  return R*2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a));
}
function renderNearbyCoursesList(){
  var el=document.getElementById('nearby-list');if(!el||!nearbyCourses.length)return;
  el.innerHTML='<div style="font-size:.75rem;font-weight:600;color:var(--tl);text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px;">'+t('nearbyTap')+'</div>'
    +nearbyCourses.slice(0,8).map(function(c){
      var safe=c.name.replace(/'/g,"\\'");
      return '<div class="nearby-card" onclick="selectNearbyCourse(\''+safe+'\')">'
        +'<div style="width:36px;height:36px;border-radius:50%;background:var(--g1);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;">⛳</div>'
        +'<div style="flex:1;min-width:0;"><div style="font-weight:600;font-size:.88rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">'+c.name+'</div>'
        +'<div style="font-size:.73rem;color:var(--tl);">'+c.address+'</div></div>'
        +'<div style="background:var(--g1);color:var(--g8);font-size:.72rem;font-weight:700;padding:4px 10px;border-radius:20px;flex-shrink:0;">'+c.dist+'</div></div>';
    }).join('');
}

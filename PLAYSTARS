// ── START ROUND ──
function startRound(){
  var course=document.getElementById('setup-course').value.trim()||'Golf Course';
  var holes=parseInt(document.getElementById('setup-holes').value);
  var par=parseInt(document.getElementById('setup-par').value)||(holes===9?36:72);
  var rating=parseFloat(document.getElementById('setup-rating').value)||(holes===9?36:72);
  var slope=parseInt(document.getElementById('setup-slope').value)||113;
  var date=document.getElementById('setup-date').value;
  var pars=[];for(var i=0;i<holes;i++)pars.push(Math.max(3,Math.min(5,Math.round(par/holes))));
  activeRound={course:course,holes:holes,par:par,rating:rating,slope:slope,date:date,mode:selectedMode,scores:new Array(holes).fill(''),pars:pars};
  showTab('scorecard');
}

// ── SCORECARD ──
function renderScorecard(){
  var wrapper=document.getElementById('scorecard-wrapper'),nomsg=document.getElementById('no-round-msg');
  if(!activeRound){wrapper.style.display='none';nomsg.style.display='block';return;}
  wrapper.style.display='block';nomsg.style.display='none';
  document.getElementById('sc-course-name').textContent=activeRound.course;
  document.getElementById('sc-mode-info').textContent=modeName(activeRound.mode);
  document.getElementById('scorecard-rows').innerHTML=activeRound.pars.map(function(par,i){
    var sc=activeRound.scores[i];
    var diff=sc!==''?parseInt(sc)-par:null;
    var diffHTML='<span style="color:var(--tl)">–</span>',cc='';
    if(diff!==null){
      if(diff<=-2){diffHTML='<span style="color:#1a6b8a">'+diff+'</span>';cc='c-eagle';}
      else if(diff===-1){diffHTML='<span style="color:var(--ok)">-1</span>';cc='c-birdie';}
      else if(diff===0){diffHTML='<span style="color:var(--tm)">E</span>';cc='c-par';}
      else if(diff===1){diffHTML='<span style="color:var(--gold-d)">+1</span>';cc='c-bogey';}
      else{diffHTML='<span style="color:var(--danger)">+'+diff+'</span>';cc='c-double';}
    }
    return '<div class="hole-row">'
      +'<div class="hole-num">'+(i+1)+'</div>'
      +'<div><div class="sc-circle '+cc+'" style="'+(cc?'':'background:var(--cream);color:var(--tl);')+'">'+par+'</div></div>'
      +'<input class="hole-score-input" type="number" min="1" max="15" value="'+sc+'" placeholder="–" oninput="updateScore('+i+',this.value)" onfocus="this.select()">'
      +'<div style="text-align:center;font-size:.78rem;font-weight:700;">'+diffHTML+'</div></div>';
  }).join('');
  updateScorecardTotals();
}
function updateScore(i,v){activeRound.scores[i]=v;updateScorecardTotals();}
function updateScorecardTotals(){
  var scores=activeRound.scores.map(function(s){return s!==''?parseInt(s):null;});
  var done=scores.filter(function(s){return s!==null;}).length;
  var total=scores.reduce(function(a,s){return a+(s||0);},0);
  var parSoFar=activeRound.pars.slice(0,done).reduce(function(a,p){return a+p;},0);
  var vp=total-parSoFar;
  document.getElementById('sc-total-score').textContent=total||0;
  document.getElementById('sc-vs-par').textContent=vp===0?'E':(vp>0?'+'+vp:vp);
  document.getElementById('sc-completed').textContent=done+'/'+activeRound.holes;
}
function finishRound(){
  var scores=activeRound.scores.map(function(s){return s!==''?parseInt(s):null;});
  var total=scores.reduce(function(a,s){return a+(s||0);},0);
  var parTotal=activeRound.pars.reduce(function(a,p){return a+p;},0);
  var vsPar=total-parTotal;
  var diff=((total-activeRound.rating)*113/activeRound.slope).toFixed(1);
  var sfPts=0;
  scores.forEach(function(s,i){if(s===null)return;var d=s-activeRound.pars[i];if(d<=-2)sfPts+=4;else if(d===-1)sfPts+=3;else if(d===0)sfPts+=2;else if(d===1)sfPts+=1;});
  var vsParStr=vsPar===0?'E':(vsPar>0?'+'+vsPar:String(vsPar));
  document.getElementById('summary-content').innerHTML=
    '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:1rem;">'
    +'<div class="stat-card"><div class="stat-value">'+total+'</div><div class="stat-label">'+t('total')+'</div></div>'
    +'<div class="stat-card"><div class="stat-value">'+vsParStr+'</div><div class="stat-label">'+t('vsPar')+'</div></div></div>'
    +'<div style="background:var(--cream);border-radius:10px;padding:12px;margin-bottom:12px;font-size:.85rem;">'
    +'<div style="display:flex;justify-content:space-between;margin-bottom:6px;"><span style="color:var(--tm);">'+t('course')+'</span><strong>'+activeRound.course+'</strong></div>'
    +'<div style="display:flex;justify-content:space-between;margin-bottom:6px;"><span style="color:var(--tm);">Mode</span><span class="gold-badge">'+modeName(activeRound.mode)+'</span></div>'
    +'<div style="display:flex;justify-content:space-between;"><span style="color:var(--tm);">'+t('diffEstimated')+'</span><strong>'+diff+'</strong></div></div>'
    +(activeRound.mode==='stableford'?'<div style="padding:10px;background:var(--g1);border-radius:10px;text-align:center;"><div style="font-size:.8rem;color:var(--g7);font-weight:600;">Stableford Points</div><div style="font-size:2rem;font-weight:700;color:var(--g9);font-family:\'Playfair Display\',serif;">'+sfPts+'</div></div>':'');
  document.getElementById('modal-summary').classList.add('open');
}
function saveRound(){
  var scores=activeRound.scores.map(function(s){return s!==''?parseInt(s):null;});
  var total=scores.reduce(function(a,s){return a+(s||0);},0);
  var parTotal=activeRound.pars.reduce(function(a,p){return a+p;},0);
  var round={id:Date.now(),course:activeRound.course,date:activeRound.date,mode:activeRound.mode,holes:activeRound.holes,par:parTotal,scores:activeRound.scores,pars:activeRound.pars,total:total,vsPar:total-parTotal,rating:activeRound.rating,slope:activeRound.slope,differential:((total-activeRound.rating)*113/activeRound.slope).toFixed(1)};
  saveRoundToDB(currentUser.username,round);
  var rounds=getRounds(currentUser.username);
  var diffs=rounds.map(function(r){return parseFloat(r.differential);}).filter(function(d){return !isNaN(d);}).sort(function(a,b){return a-b;});
  var best8=diffs.slice(0,Math.min(8,diffs.length));
  if(best8.length>0){var avg=best8.reduce(function(a,b){return a+b;},0)/best8.length;currentUser.handicap=Math.max(0,avg*0.96).toFixed(1);}
  var db=getDB();if(db.users&&db.users[currentUser.username])db.users[currentUser.username].handicap=currentUser.handicap;saveDB(db);
  activeRound=null;closeModal('modal-summary');showToast(t('roundSaved'));showTab('home');
}
